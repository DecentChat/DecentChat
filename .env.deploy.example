# Deploy credentials — copy to .env.deploy and fill in values
# .env.deploy is gitignored; this file is safe to commit

DEPLOY_HOST=your-ftp-host-or-ip
DEPLOY_USER=your-ftp-username
DEPLOY_PASS=your-ftp-password
DEPLOY_REMOTE_PATH=decentchat.app/web/
DEPLOY_DOCS_REMOTE_PATH=decentchat.app/sub/docs/  # Websupport subdomain docs.decentchat.app maps here
