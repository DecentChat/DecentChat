{
  "name": "decent-chat",
  "version": "0.1.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "peer": "^1.0.2",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4"
  },
  "description": "Monorepo for decent-protocol SDK and decent-client-web reference implementation",
  "private": true,
  "scripts": {
    "test": "cd decent-protocol && bun run test",
    "test:protocol": "cd decent-protocol && bun run test",
    "build:client": "cd decent-client-web && bun run build",
    "dev:client": "cd decent-client-web && bun run dev",
    "dev:signal": "bun run scripts/signaling-server.ts",
    "dev": "bun run dev:signal & bun run dev:client",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy:docs": "./scripts/deploy-docs.sh",
    "test:e2e": "cd decent-client-web && bun run test:e2e",
    "test:integration": "cd decent-client-web && bun run test:integration",
    "test:unit": "cd decent-client-web && bun run test:unit",
    "test:mobile": "cd decent-client-mobile && bun run test:e2e",
    "test:mobile:headed": "cd decent-client-mobile && bun run test:e2e:headed",
    "test:mobile:ui": "cd decent-client-mobile && bun run test:e2e:ui",
    "test:all": "bun test && cd decent-client-web && bun run test:unit && bun run test:integration:migration",
    "typecheck": "tsc --build tsconfig.json",
    "perf:smoke": "cd decent-protocol && bun run tests/perf/run.ts --scenario=smoke --check-integrity",
    "perf:reconnect": "cd decent-protocol && bun run tests/perf/run.ts --scenario=reconnect-chaos --check-integrity",
    "gate:predeploy": "cd decent-protocol && bun test tests/unit/perf-integrity-audit.test.ts && bun run tests/perf/run.ts --scenario=smoke --check-integrity --peers=20 && bun run tests/perf/run.ts --scenario=reconnect-chaos --check-integrity --peers=20",
    "gate:quick": "cd decent-protocol && bun test tests/unit/perf-integrity-audit.test.ts && bun run tests/perf/run.ts --scenario=smoke --check-integrity --peers=5",
    "test:e2e:live-smoke": "cd decent-client-web && bun run test:e2e:live-smoke"
  },
  "workspaces": [
    "decent-protocol",
    "decent-transport-webrtc",
    "decent-client-web",
    "decent-client-core",
    "decent-client-mobile",
    "decent-openclaw",
    "decent-company-sim",
    "decent-hermes"
  ]
}
