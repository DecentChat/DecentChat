{
  "name": "decent-protocol",
  "version": "0.1.0",
  "description": "Transport-agnostic protocol SDK for serverless, E2E-encrypted, CRDT-based P2P messaging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "bun": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "p2p",
    "crdt",
    "e2e-encryption",
    "mesh",
    "protocol",
    "vector-clock",
    "negentropy",
    "webrtc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alino/DecentChat.git",
    "directory": "decent-protocol"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1"
  }
}
