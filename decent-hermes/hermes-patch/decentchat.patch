+        assert adapter._invites == ["decent://invite/a", "decent://invite/b"]
+        assert str(adapter._data_dir).endswith("/tmp/decentchat-test-data")
+        assert adapter._stt_engine == "openai"
+        assert adapter._tts_engine == "elevenlabs"
+        assert adapter._tts_api_key == "secret"
+        assert adapter._tts_voice == "voice-id"
