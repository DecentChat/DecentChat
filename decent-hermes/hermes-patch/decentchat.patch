+"""
+DecentChat semantic search (RAG) service.
+
+Maintains a vector index of all DecentChat messages Xena has access to,
+backed by a local Ollama embedding model (nomic-embed-text). Provides a
+query interface the agent tool `decentchat_search` calls.
+
+Storage layout (per Xena instance):
+    ~/.hermes/decentchat/embeddings/
+        vectors.npy       ← float32[N, 768]   L2-normalized embeddings
+        metadata.jsonl    ← one JSON line per row, matching vectors index
+        index.json        ← { "model": "nomic-embed-text", "dim": 768,
+                               "count": N, "last_backfill_ts": ... }
+
+Design notes:
+  - Embeddings are L2-normalized at write time → cosine similarity becomes
+    a plain dot product at query time (faster).
+  - Metadata is a JSONL append-log, not a database, so incremental writes
+    are O(1) and crash-safe.
+  - The vectors.npy is memmap-loaded at service start and kept resident
+    in RAM for query-time brute-force search. At <100k messages this is
+    < 300 MB and query latency is ~20 ms per search.
+  - Content hashing prevents duplicate embedding on backfill re-runs.
+"""
+
+from __future__ import annotations
+
+import asyncio
+import hashlib
+import json
+import logging
+import os
+import sqlite3
+import time
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any, Dict, List, Optional, Tuple
+
+import numpy as np
+
+logger = logging.getLogger(__name__)
+
+OLLAMA_URL = os.getenv("OLLAMA_BASE_URL", "http://127.0.0.1:11434").rstrip("/")
+EMBED_MODEL = os.getenv("DECENTCHAT_RAG_MODEL", "nomic-embed-text")
+EMBED_DIM = 768  # nomic-embed-text
+
+
+@dataclass
+class MessageMeta:
+    """Metadata for a single indexed message."""
+    message_id: str
+    channel_id: str
+    workspace_id: str
+    sender_id: str
+    sender_name: str
+    timestamp: int          # ms since epoch
+    content: str
+    content_hash: str       # sha256 of content, prevents dup embeds
+
+    @classmethod
+    def from_dict(cls, d: Dict[str, Any]) -> "MessageMeta":
+        return cls(
+            message_id=str(d.get("message_id") or d.get("id") or ""),
+            channel_id=str(d.get("channel_id") or d.get("channelId") or ""),
+            workspace_id=str(d.get("workspace_id") or d.get("workspaceId") or ""),
+            sender_id=str(d.get("sender_id") or d.get("senderId") or ""),
+            sender_name=str(d.get("sender_name") or d.get("senderName") or ""),
+            timestamp=int(d.get("timestamp") or 0),
+            content=str(d.get("content") or ""),
+            content_hash=str(d.get("content_hash") or ""),
+        )
+
+    def to_dict(self) -> Dict[str, Any]:
+        return {
+            "message_id": self.message_id,
+            "channel_id": self.channel_id,
+            "workspace_id": self.workspace_id,
+            "sender_id": self.sender_id,
+            "sender_name": self.sender_name,
+            "timestamp": self.timestamp,
+            "content": self.content,
+            "content_hash": self.content_hash,
+        }
+
+
+@dataclass
+class SearchResult:
+    score: float
+    meta: MessageMeta
+    channel_name: Optional[str] = None
+    workspace_name: Optional[str] = None
+
+
+class DecentChatRAG:
+    """In-memory vector index + Ollama embedding client."""
+
+    def __init__(
+        self,
+        data_dir: Path = Path.home() / ".hermes" / "decentchat" / "embeddings",
+        store_db: Path = Path.home() / ".hermes" / "decentchat" / "data" / "store.db",
+    ):
+        self.data_dir = data_dir
+        self.data_dir.mkdir(parents=True, exist_ok=True)
+        self.vectors_path = self.data_dir / "vectors.npy"
+        self.metadata_path = self.data_dir / "metadata.jsonl"
+        self.index_path = self.data_dir / "index.json"
+        self.store_db = store_db
+
+        # In-memory state
+        self._vectors: Optional[np.ndarray] = None      # (N, 768) float32, L2-normalized
+        self._metadata: List[MessageMeta] = []
+        self._hash_set: set[str] = set()                # for O(1) dup detection
+        self._lock = asyncio.Lock()                     # for concurrent writes
+        self._ws_name_cache: Dict[str, str] = {}
+        self._channel_name_cache: Dict[str, str] = {}
+
+        # Cached aiohttp session for Ollama (created lazily in async context)
+        self._http_session = None
+
+    # ------------------------------------------------------------------
+    # Lifecycle
+    # ------------------------------------------------------------------
+
+    def load(self) -> None:
+        """Load existing index from disk."""
+        if self.vectors_path.exists() and self.metadata_path.exists():
+            try:
+                self._vectors = np.load(str(self.vectors_path), mmap_mode="r")
+                self._metadata = []
+                with open(self.metadata_path, "r", encoding="utf-8") as f:
+                    for line in f:
+                        line = line.strip()
+                        if not line:
+                            continue
+                        try:
+                            self._metadata.append(MessageMeta.from_dict(json.loads(line)))
+                        except Exception as e:
+                            logger.warning("Skipping corrupt metadata line: %s", e)
+                self._hash_set = {m.content_hash for m in self._metadata}
+                if self._vectors.shape[0] != len(self._metadata):
+                    logger.error(
+                        "Index corruption: vectors=%d metadata=%d — rebuild needed",
+                        self._vectors.shape[0], len(self._metadata),
+                    )
+                    self._vectors = None
+                    self._metadata = []
+                    self._hash_set = set()
+                else:
+                    logger.info(
+                        "[DecentChatRAG] Loaded %d vectors from disk",
+                        self._vectors.shape[0],
+                    )
+            except Exception as e:
+                logger.warning("Failed to load index: %s — starting fresh", e)
+                self._vectors = None
+                self._metadata = []
+                self._hash_set = set()
+
+    async def close(self) -> None:
+        if self._http_session is not None:
+            try:
+                await self._http_session.close()
+            except Exception:
+                pass
+            self._http_session = None
+
+    @property
+    def count(self) -> int:
+        return len(self._metadata)
+
+    # ------------------------------------------------------------------
+    # Embedding (Ollama client — sync HTTP via urllib to avoid asyncio
+    # cross-event-loop issues when called from tool handlers)
+    # ------------------------------------------------------------------
+
+    def _embed_sync(self, text: str) -> np.ndarray:
+        """Synchronous embed — uses urllib to avoid aiohttp cross-loop issues.
+
+        Bound to no event loop, safe to call from any thread.  The Ollama
+        embedding call is ~5-10 ms which is fast enough that we don't need
+        concurrency here.
+        """
+        if not text or not text.strip():
+            return np.zeros(EMBED_DIM, dtype=np.float32)
+        import urllib.request
+        import urllib.error
+        req = urllib.request.Request(
+            f"{OLLAMA_URL}/api/embeddings",
+            data=json.dumps({"model": EMBED_MODEL, "prompt": text}).encode("utf-8"),
+            headers={"Content-Type": "application/json"},
+            method="POST",
+        )
+        try:
+            with urllib.request.urlopen(req, timeout=30) as resp:
+                body = resp.read()
+        except urllib.error.HTTPError as e:
+            raise RuntimeError(f"Ollama embed HTTP {e.code}: {e.read()[:200]}")
+        data = json.loads(body)
+        vec = np.asarray(data["embedding"], dtype=np.float32)
+        if vec.shape[0] != EMBED_DIM:
+            raise RuntimeError(
+                f"Unexpected embedding dim {vec.shape[0]} (wanted {EMBED_DIM})"
+            )
+        norm = np.linalg.norm(vec)
+        if norm > 0:
+            vec = vec / norm
+        return vec
+
+    async def embed(self, text: str) -> np.ndarray:
+        """Async wrapper around the sync embed call — runs in a thread
+        executor so the event loop stays responsive during the Ollama HTTP
+        round-trip."""
+        return await asyncio.get_event_loop().run_in_executor(
+            None, self._embed_sync, text
+        )
+
+    async def embed_batch(self, texts: List[str], concurrency: int = 4) -> List[np.ndarray]:
+        """Embed a list of texts concurrently (bounded by concurrency)."""
+        sem = asyncio.Semaphore(concurrency)
+
+        async def _one(t: str) -> np.ndarray:
+            async with sem:
+                return await self.embed(t)
+
+        return await asyncio.gather(*(_one(t) for t in texts))
+
+    # ------------------------------------------------------------------
+    # Index maintenance
+    # ------------------------------------------------------------------
+
+    @staticmethod
+    def _content_hash(content: str) -> str:
+        return hashlib.sha256(content.encode("utf-8", errors="ignore")).hexdigest()
+
+    # Prefixes that indicate the message is a Hermes agent tool-output
+    # artifact (not natural language worth indexing for semantic search).
+    _TOOL_OUTPUT_PREFIXES: Tuple[str, ...] = (
+        "📖 read_file",
+        "🔎 search_files",
+        "🔍 search_files",
+        "🔍 session_search",
+        "📝 write_file",
+        "🔧 patch",
+        "⚙️ terminal",
+        "🌐 web_",
+        "🌐 browser_",
+        "🖼 vision_",
+        "🎤 text_to_speech",
+        "⏳ cronjob",
+        "📋 todo",
+        "💬 clarify",
+        "🧠 memory",
+        "🎯 skill",
+        "📡 delegate_task",
+        "🗂 skill_view",
+        "🗂 skills_list",
+    )
+
+    @classmethod
+    def _should_index(cls, content: str) -> bool:
+        """Filter out messages that shouldn't be indexed: emoji-only, tool
+        output artifacts, URL-only, or too short to be semantically useful.
+        """
+        s = (content or "").strip()
+        if len(s) < 10:
+            return False
+        # Starts with a tool-output emoji marker
+        for prefix in cls._TOOL_OUTPUT_PREFIXES:
+            if s.startswith(prefix):
+                return False
+        # Mostly emoji / punctuation? Count letters.
+        letters = sum(1 for c in s if c.isalpha())
+        if letters < 5:
+            return False
+        return True
+
+    async def add_message(
+        self,
+        message_id: str,
+        channel_id: str,
+        workspace_id: str,
+        sender_id: str,
+        sender_name: str,
+        timestamp: int,
+        content: str,
+    ) -> bool:
+        """Add a single message to the index. No-op if content already embedded."""
+        if not self._should_index(content):
+            return False
+        chash = self._content_hash(content)
+        async with self._lock:
+            if chash in self._hash_set:
+                return False
+            meta = MessageMeta(
+                message_id=message_id,
+                channel_id=channel_id,
+                workspace_id=workspace_id,
+                sender_id=sender_id,
+                sender_name=sender_name,
+                timestamp=timestamp,
+                content=content,
+                content_hash=chash,
+            )
+            try:
+                vec = await self.embed(content)
+            except Exception as e:
+                logger.warning("Embed failed for msg %s: %s", message_id[:8], e)
+                return False
+            # Append to in-memory + disk atomically
+            if self._vectors is None:
+                self._vectors = vec.reshape(1, -1).copy()
+            else:
+                # mmap arrays are read-only; promote to RAM if needed
+                if not self._vectors.flags.writeable:
+                    self._vectors = np.array(self._vectors)
+                self._vectors = np.vstack([self._vectors, vec.reshape(1, -1)])
+            self._metadata.append(meta)
+            self._hash_set.add(chash)
+            # Append to JSONL (cheap, atomic)
+            with open(self.metadata_path, "a", encoding="utf-8") as f:
+                f.write(json.dumps(meta.to_dict(), ensure_ascii=False) + "\n")
+            # Rewrite vectors.npy (cheap at this scale; can batch later if needed)
+            self._save_vectors()
+            return True
+
+    def _save_vectors(self) -> None:
+        if self._vectors is None:
+            return
+        # Write to a tmp file (raw bytes via np.lib.format to avoid np.save's
+        # auto-.npy suffix appending), then atomic rename.
+        tmp = self.vectors_path.parent / (self.vectors_path.name + ".tmp")
+        arr = np.ascontiguousarray(self._vectors.astype(np.float32))
+        with open(tmp, "wb") as f:
+            np.lib.format.write_array(f, arr, allow_pickle=False)
+        os.replace(tmp, self.vectors_path)
+        with open(self.index_path, "w", encoding="utf-8") as f:
+            json.dump(
+                {
+                    "model": EMBED_MODEL,
+                    "dim": EMBED_DIM,
+                    "count": int(self._vectors.shape[0]),
+                    "updated_at": int(time.time()),
+                },
+                f,
+            )
+
+    # ------------------------------------------------------------------
+    # Backfill from bridge SQLite store
+    # ------------------------------------------------------------------
+
+    async def backfill(self, limit: Optional[int] = None) -> Dict[str, int]:
+        """Walk all messages-<channel> rows in store.db and embed missing ones."""
+        if not self.store_db.exists():
+            logger.warning("store.db not found at %s — skipping backfill", self.store_db)
+            return {"scanned": 0, "embedded": 0, "skipped": 0}
+
+        conn = sqlite3.connect(f"file:{self.store_db}?mode=ro", uri=True, timeout=5)
+        try:
+            cur = conn.cursor()
+            cur.execute("SELECT key, value FROM kv WHERE key LIKE 'messages-%'")
+            rows = cur.fetchall()
+        finally:
+            conn.close()
+
+        # Also pull workspace membership for name resolution
+        self._refresh_workspace_cache()
+
+        scanned = 0
+        embedded = 0
+        skipped = 0
+        queue: List[Tuple[MessageMeta, str]] = []
+
+        for key, value in rows:
+            channel_id = key[len("messages-"):]
+            try:
+                msgs = json.loads(value)
+            except Exception:
+                continue
+            if not isinstance(msgs, list):
+                continue
+            workspace_id = self._channel_to_workspace(channel_id)
+            for m in msgs:
+                if not isinstance(m, dict):
+                    continue
+                content = (m.get("content") or "").strip()
+                scanned += 1
+                if not self._should_index(content):
+                    skipped += 1
+                    continue
+                chash = self._content_hash(content)
+                if chash in self._hash_set:
+                    skipped += 1
+                    continue
+                meta = MessageMeta(
+                    message_id=str(m.get("id") or ""),
+                    channel_id=channel_id,
+                    workspace_id=workspace_id,
+                    sender_id=str(m.get("senderId") or ""),
+                    sender_name=str(m.get("senderName") or ""),
+                    timestamp=int(m.get("timestamp") or 0),
+                    content=content,
+                    content_hash=chash,
+                )
+                queue.append((meta, content))
+                if limit is not None and len(queue) >= limit:
+                    break
+            if limit is not None and len(queue) >= limit:
+                break
+
+        if not queue:
+            logger.info("[DecentChatRAG] Backfill: nothing new to embed (scanned=%d)", scanned)
+            return {"scanned": scanned, "embedded": 0, "skipped": skipped}
+
+        logger.info(
+            "[DecentChatRAG] Backfill: embedding %d new messages (scanned=%d, skipped=%d)",
+            len(queue), scanned, skipped,
+        )
+        # Embed in batches
+        async with self._lock:
+            new_vectors = []
+            with open(self.metadata_path, "a", encoding="utf-8") as f:
+                # Use small sub-batches so we can checkpoint along the way
+                BATCH = 32
+                for i in range(0, len(queue), BATCH):
+                    sub = queue[i:i+BATCH]
+                    texts = [c for _, c in sub]
+                    try:
+                        vecs = await self.embed_batch(texts, concurrency=4)
+                    except Exception as e:
+                        logger.warning("Batch embed failed (batch %d): %s", i // BATCH, e)
+                        continue
+                    for (meta, _), vec in zip(sub, vecs):
+                        new_vectors.append(vec)
+                        self._metadata.append(meta)
+                        self._hash_set.add(meta.content_hash)
+                        f.write(json.dumps(meta.to_dict(), ensure_ascii=False) + "\n")
+                        embedded += 1
+                    f.flush()
+                    if (i // BATCH) % 4 == 3:
+                        logger.info(
+                            "[DecentChatRAG] backfill progress: %d/%d embedded",
+                            embedded, len(queue),
+                        )
+            if new_vectors:
+                block = np.vstack([v.reshape(1, -1) for v in new_vectors]).astype(np.float32)
+                if self._vectors is None:
+                    self._vectors = block
+                else:
+                    if not self._vectors.flags.writeable:
+                        self._vectors = np.array(self._vectors)
+                    self._vectors = np.vstack([self._vectors, block])
+                self._save_vectors()
+
+        return {"scanned": scanned, "embedded": embedded, "skipped": skipped}
+
+    # ------------------------------------------------------------------
+    # Workspace / channel name resolution (from store.db)
+    # ------------------------------------------------------------------
+
+    def _refresh_workspace_cache(self) -> None:
+        self._ws_name_cache = {}
+        self._channel_name_cache = {}
+        if not self.store_db.exists():
+            return
+        conn = sqlite3.connect(f"file:{self.store_db}?mode=ro", uri=True, timeout=5)
+        try:
+            cur = conn.cursor()
+            cur.execute("SELECT value FROM kv WHERE key = 'workspaces'")
+            row = cur.fetchone()
+            if row and row[0]:
+                try:
+                    ws_list = json.loads(row[0])
+                    if isinstance(ws_list, list):
+                        for ws in ws_list:
+                            wid = str(ws.get("id") or "")
+                            wname = str(ws.get("name") or "")
+                            if wid:
+                                self._ws_name_cache[wid] = wname
+                            for ch in ws.get("channels", []) or []:
+                                cid = str(ch.get("id") or "")
+                                cname = str(ch.get("name") or "")
+                                if cid:
+                                    self._channel_name_cache[cid] = cname
+                except Exception:
+                    pass
+        finally:
+            conn.close()
+
+    def _channel_to_workspace(self, channel_id: str) -> str:
+        """Scan workspace cache for channel's owning workspace id."""
+        if not self._ws_name_cache:
+            self._refresh_workspace_cache()
+        if not self.store_db.exists():
+            return ""
+        conn = sqlite3.connect(f"file:{self.store_db}?mode=ro", uri=True, timeout=5)
+        try:
+            cur = conn.cursor()
+            cur.execute("SELECT value FROM kv WHERE key = 'workspaces'")
+            row = cur.fetchone()
+            if not row or not row[0]:
+                return ""
+            try:
+                ws_list = json.loads(row[0])
+                if isinstance(ws_list, list):
+                    for ws in ws_list:
+                        for ch in ws.get("channels", []) or []:
+                            if str(ch.get("id") or "") == channel_id:
+                                return str(ws.get("id") or "")
+            except Exception:
+                pass
+        finally:
+            conn.close()
+        return ""
+
+    # ------------------------------------------------------------------
+    # Search
+    # ------------------------------------------------------------------
+
+    def search_sync(
+        self,
+        query: str,
+        k: int = 10,
+        workspace: Optional[str] = None,
+        channel: Optional[str] = None,
+        sender: Optional[str] = None,
+        since_ts: Optional[int] = None,
+        until_ts: Optional[int] = None,
+        recency_boost: float = 0.05,
+    ) -> List[SearchResult]:
+        """Synchronous version of search — safe to call from any context
+        (no event loop dependency).  Used by the agent tool handler which
+        runs on the main loop but can't safely await from within a sync
+        dispatch.
+        """
+        if self._vectors is None or self.count == 0:
+            return []
+        q_vec = self._embed_sync(query)
+        return self._rank_and_filter(
+            q_vec, k=k, workspace=workspace, channel=channel, sender=sender,
+            since_ts=since_ts, until_ts=until_ts, recency_boost=recency_boost,
+        )
+
+    def _rank_and_filter(
+        self,
+        q_vec: np.ndarray,
+        k: int,
+        workspace: Optional[str],
+        channel: Optional[str],
+        sender: Optional[str],
+        since_ts: Optional[int],
+        until_ts: Optional[int],
+        recency_boost: float,
+    ) -> List[SearchResult]:
+        """Compute similarity + apply filters + return top-K (sync helper
+        shared between sync and async search paths)."""
+        # Dot product because vectors are L2-normalized → cosine similarity
+        scores = self._vectors @ q_vec  # (N,)
+
+        # Apply mild recency boost: newer messages get a small additive bump
+        if recency_boost > 0 and self._metadata:
+            now_ms = int(time.time() * 1000)
+            ages = np.array(
+                [max(0, now_ms - m.timestamp) for m in self._metadata], dtype=np.float32
+            )
+            day_ms = 24 * 3600 * 1000
+            age_norm = np.clip(ages / (30 * day_ms), 0.0, 1.0)
+            scores = scores + recency_boost * (1.0 - age_norm)
+
+        # Refresh name cache if filters / output need it
+        if not self._ws_name_cache:
+            self._refresh_workspace_cache()
+
+        # Build mask for filters
+        mask = np.ones(len(self._metadata), dtype=bool)
+        if workspace:
+            mask &= np.array([m.workspace_id == workspace for m in self._metadata])
+        if channel:
+            mask &= np.array([m.channel_id == channel for m in self._metadata])
+        if sender:
+            sl = sender.lower()
+            mask &= np.array(
+                [(m.sender_id == sender) or (sl in (m.sender_name or "").lower())
+                 for m in self._metadata]
+            )
+        if since_ts is not None:
+            mask &= np.array([m.timestamp >= since_ts for m in self._metadata])
+        if until_ts is not None:
+            mask &= np.array([m.timestamp <= until_ts for m in self._metadata])
+
+        filtered_scores = np.where(mask, scores, -np.inf)
+        if not np.isfinite(filtered_scores).any():
+            return []
+
+        k = max(1, min(k, int(mask.sum())))
+        top_idx = np.argpartition(-filtered_scores, k - 1)[:k]
+        top_idx = top_idx[np.argsort(-filtered_scores[top_idx])]
+
+        results = []
+        for i in top_idx:
+            meta = self._metadata[int(i)]
+            results.append(
+                SearchResult(
+                    score=float(filtered_scores[int(i)]),
+                    meta=meta,
+                    channel_name=self._channel_name_cache.get(meta.channel_id),
+                    workspace_name=self._ws_name_cache.get(meta.workspace_id),
+                )
+            )
+        return results
+
+    async def search(
+        self,
+        query: str,
+        k: int = 10,
+        workspace: Optional[str] = None,
+        channel: Optional[str] = None,
+        sender: Optional[str] = None,
+        since_ts: Optional[int] = None,
+        until_ts: Optional[int] = None,
+        recency_boost: float = 0.05,
+    ) -> List[SearchResult]:
+        """Semantic search with optional filters and mild recency boost."""
+        if self._vectors is None or self.count == 0:
+            return []
+        q_vec = await self.embed(query)
+        return self._rank_and_filter(
+            q_vec, k=k, workspace=workspace, channel=channel, sender=sender,
+            since_ts=since_ts, until_ts=until_ts, recency_boost=recency_boost,
+        )
+
+
+# Singleton accessor for gateway integration
+_rag_instance: Optional[DecentChatRAG] = None
+
+
+def get_rag() -> DecentChatRAG:
+    global _rag_instance
+    if _rag_instance is None:
+        _rag_instance = DecentChatRAG()
+        _rag_instance.load()
+    return _rag_instance
