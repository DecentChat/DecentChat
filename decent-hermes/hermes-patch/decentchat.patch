+def _dequeue_pending_event(adapter, session_key: str):
+    """Consume and return the full pending MessageEvent (for threading).
+
+    Returns a tuple (text, message_id, thread_id) so the caller can pass
+    them to the recursive _run_agent call and the follow-up reply lands in
+    the correct thread of the correct user message.  Returns None if no
+    pending message.
