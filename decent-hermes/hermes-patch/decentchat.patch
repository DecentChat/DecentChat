+async def _send_decentchat(pconfig, chat_id: str, message: str):
+    """Send a DecentChat message directly via the bridge HTTP API."""
+    try:
+        import aiohttp
+    except ImportError:
+        return {"error": "aiohttp not installed. Run: pip install aiohttp"}
+
+    port = pconfig.extra.get("bridge_port", 3001)
+    url = f"http://127.0.0.1:{port}/send"
+    try:
+        async with aiohttp.ClientSession() as session:
+            async with session.post(
+                url,
+                json={"chatId": chat_id, "body": message},
+                timeout=aiohttp.ClientTimeout(total=10),
+            ) as resp:
+                if resp.status != 200:
+                    body = await resp.text()
+                    return {"error": f"DecentChat bridge error ({resp.status}): {body}"}
+                data = await resp.json()
+                if data.get("success"):
+                    return {
+                        "success": True,
+                        "platform": "decentchat",
+                        "chat_id": chat_id,
+                        "message_id": data.get("messageId"),
+                    }
+                return {"error": data.get("error", "DecentChat send failed")}
+    except Exception as e:
+        return {"error": f"DecentChat send failed: {e}"}
+
