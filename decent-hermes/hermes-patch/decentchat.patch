@@ -0,0 +1,119 @@
+"""Integration smoke test for the DecentChat bridge subprocess."""
+
+import asyncio
+import os
+import platform as _platform
+import signal
+import socket
+import subprocess
+from pathlib import Path
+
+import pytest
+
+
+def _free_port() -> int:
+    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
+        s.bind(("127.0.0.1", 0))
+        return int(s.getsockname()[1])
+
+
+def _terminate_process(proc: subprocess.Popen) -> None:
+    if proc.poll() is not None:
+        return
+    if _platform.system() == "Windows":
+        proc.terminate()
+    else:
+        try:
+            os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
+        except ProcessLookupError:
+            return
+        except PermissionError:
+            proc.terminate()
+    try:
+        proc.wait(timeout=10)
+    except subprocess.TimeoutExpired:
+        if _platform.system() == "Windows":
+            proc.kill()
+        else:
+            try:
+                os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
+            except ProcessLookupError:
+                pass
+        proc.wait(timeout=10)
+
+
+@pytest.mark.integration
+@pytest.mark.asyncio
+async def test_decentchat_bridge_health_and_send(tmp_path):
+    seed = os.getenv("DECENTCHAT_TEST_SEED", "").strip()
+    if not seed:
+        pytest.skip("Set DECENTCHAT_TEST_SEED to run DecentChat integration test")
+
+    bridge_path = Path(__file__).resolve().parents[2] / "scripts" / "decentchat-bridge" / "bridge.js"
+    if not bridge_path.exists():
+        pytest.skip(f"Bridge script not found: {bridge_path}")
+
+    port = _free_port()
+    data_dir = tmp_path / "decentchat-data"
+    data_dir.mkdir(parents=True, exist_ok=True)
+
+    proc = subprocess.Popen(
+        [
+            "node",
+            str(bridge_path),
+            "--port",
+            str(port),
+            "--seed-phrase",
+            seed,
+            "--alias",
+            "Hermes Integration Test",
+            "--data-dir",
+            str(data_dir),
+            "--no-huddle",
+        ],
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        text=True,
+        preexec_fn=None if _platform.system() == "Windows" else os.setsid,
+    )
+
+    try:
+        import aiohttp
+
+        health = None
+        async with aiohttp.ClientSession() as session:
+            for _ in range(120):
+                if proc.poll() is not None:
+                    logs = (proc.stdout.read() if proc.stdout else "").strip()
+                    raise AssertionError(f"Bridge exited early with code {proc.returncode}\n{logs}")
+                try:
+                    async with session.get(
+                        f"http://127.0.0.1:{port}/health",
+                        timeout=aiohttp.ClientTimeout(total=2),
+                    ) as resp:
+                        if resp.status == 200:
+                            health = await resp.json()
+                            break
+                except Exception:
+                    pass
+                await asyncio.sleep(0.25)
+
+            assert health is not None, "Bridge /health never became reachable"
+            assert "status" in health
+            assert "connected" in health
+            assert "alias" in health
+
+            async with session.post(
+                f"http://127.0.0.1:{port}/send",
+                json={"chatId": "workspace-test:general", "body": "integration ping"},
+                timeout=aiohttp.ClientTimeout(total=10),
+            ) as resp:
+                payload = await resp.json()
+
+            assert "success" in payload
+            if not payload.get("success"):
+                assert payload.get("error")
+    finally:
+        _terminate_process(proc)
+
+    assert proc.poll() is not None
