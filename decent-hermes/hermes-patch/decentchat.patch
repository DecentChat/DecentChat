+def check_decentchat_search_requirements() -> bool:
+    """Verify the RAG module is importable.
+
+    Note: The registry's contract is that check_fn returns a truthy value
+    when the tool is AVAILABLE.  Returning None (or an error string) is
+    treated as "unavailable" and the tool is silently hidden from the
+    agent — which was a subtle bug that cost several debug cycles.
+    """
+    try:
+        from gateway.platforms.decentchat_rag import get_rag  # noqa: F401
+        return True
+    except Exception as e:
+        import logging
+        logging.getLogger(__name__).debug("decentchat_search check failed: %s", e)
+        return False
+
+
+# --- Registry ---
+from tools.registry import registry
