@@ -0,0 +1,256 @@
+#!/usr/bin/env python3
+"""
+DecentChat Semantic Search Tool — Recall across past DecentChat conversations.
+
+Searches the local RAG index (Ollama nomic-embed-text vectors) of all
+messages Xena has seen on the DecentChat P2P network.  Covers multiple
+workspaces, channels, and direct messages.  Works for any language the
+embedding model supports (English, Slovak, Czech, etc.).
+
+Use this when the user references past DecentChat conversations: "čo sme
+riešili o X", "kto hovoril o Y", "ten link čo poslal Z minulý týždeň".
+
+Returns ranked hits with sender, workspace, channel, timestamp, and
+content snippet.  Does NOT search WhatsApp, Telegram, Slack, or other
+platforms — those have their own tools.
+"""
+
+from __future__ import annotations
+
+import asyncio
+import json
+import logging
+import time
+from datetime import datetime
+from typing import Any, Dict, List, Optional
+
+logger = logging.getLogger(__name__)
+
+
+def _format_timestamp(ts_ms: int) -> str:
+    """Format a ms-since-epoch timestamp as a human-readable date."""
+    try:
+        if not ts_ms or ts_ms <= 0:
+            return "unknown"
+        return datetime.fromtimestamp(ts_ms / 1000).strftime("%Y-%m-%d %H:%M")
+    except Exception:
+        return "unknown"
+
+
+def _parse_since(since: Optional[str]) -> Optional[int]:
+    """Parse a relative ('7d', '24h', '30m') or ISO-8601 'since' argument
+    into a ms-since-epoch integer.  Returns None if unparseable.
+    """
+    if not since:
+        return None
+    s = since.strip().lower()
+    now_ms = int(time.time() * 1000)
+    try:
+        if s.endswith("m"):
+            return now_ms - int(s[:-1]) * 60 * 1000
+        if s.endswith("h"):
+            return now_ms - int(s[:-1]) * 3600 * 1000
+        if s.endswith("d"):
+            return now_ms - int(s[:-1]) * 86400 * 1000
+        if s.endswith("w"):
+            return now_ms - int(s[:-1]) * 7 * 86400 * 1000
+        # ISO date fallback
+        dt = datetime.fromisoformat(s)
+        return int(dt.timestamp() * 1000)
+    except Exception:
+        return None
+
+
+def decentchat_search(
+    query: str,
+    k: int = 10,
+    workspace: Optional[str] = None,
+    channel: Optional[str] = None,
+    sender: Optional[str] = None,
+    since: Optional[str] = None,
+    **_ignored,
+) -> str:
+    """Synchronous wrapper for the tool registry.  Returns a JSON string.
+
+    Uses the RAG service's `search_sync()` method which does a urllib-based
+    Ollama call and pure numpy ranking — no asyncio, no event loop, safe
+    to call from any dispatch context.
+    """
+    if not query or not query.strip():
+        return json.dumps(
+            {"error": "query is required", "hits": []},
+            ensure_ascii=False,
+        )
+
+    try:
+        from gateway.platforms.decentchat_rag import get_rag
+    except Exception as e:
+        return json.dumps(
+            {"error": f"DecentChat RAG module not available: {e}", "hits": []},
+            ensure_ascii=False,
+        )
+
+    rag = get_rag()
+    if rag.count == 0:
+        return json.dumps(
+            {
+                "error": (
+                    "DecentChat RAG index is empty.  Either Xena hasn't seen "
+                    "any messages yet, or the backfill hasn't run.  If the "
+                    "adapter is running, wait a few seconds and try again."
+                ),
+                "hits": [],
+            },
+            ensure_ascii=False,
+        )
+
+    since_ts = _parse_since(since)
+    try:
+        results = rag.search_sync(
+            query=query,
+            k=int(k),
+            workspace=workspace,
+            channel=channel,
+            sender=sender,
+            since_ts=since_ts,
+        )
+    except Exception as e:
+        logger.exception("decentchat_search failed")
+        return json.dumps(
+            {"error": f"{type(e).__name__}: {e}", "hits": []},
+            ensure_ascii=False,
+        )
+
+    hits = []
+    for r in results:
+        snippet = r.meta.content
+        if len(snippet) > 500:
+            snippet = snippet[:500] + " …"
+        hits.append({
+            "score": round(r.score, 4),
+            "when": _format_timestamp(r.meta.timestamp),
+            "workspace": r.workspace_name or r.meta.workspace_id[:8],
+            "channel": r.channel_name or r.meta.channel_id[:8],
+            "sender": r.meta.sender_name or (r.meta.sender_id[:8] if r.meta.sender_id else ""),
+            "content": snippet,
+            "message_id": r.meta.message_id,
+            "channel_id": r.meta.channel_id,
+            "workspace_id": r.meta.workspace_id,
+        })
+
+    return json.dumps(
