+            assert check_decentchat_requirements() is False
+
+
+class TestAdapterInit:
+    def test_parses_platform_config(self):
+        config = PlatformConfig(
+            enabled=True,
+            extra={
+                "seed_phrase": "seed",
+                "bridge_port": "4201",
+                "bridge_script": "/tmp/decent-bridge.js",
+                "signaling_server": "https://signal.example",
+                "alias": "Hermes QA",
+                "invites": "decent://invite/a, decent://invite/b ",
