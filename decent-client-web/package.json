{
  "name": "decent-client-web",
  "version": "0.1.0",
  "description": "Reference web client for decent-protocol \u2014 serverless P2P chat PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "PW_SCOPE=e2e playwright test",
    "test:e2e:full": "PW_SCOPE=all playwright test",
    "test:e2e:headed": "PW_SCOPE=e2e playwright test --headed",
    "test:e2e:ui": "PW_SCOPE=e2e playwright test --ui",
    "test:integration": "bun run test:integration:bun && PW_SCOPE=integration playwright test --project=chromium",
    "test:integration:full": "bun run test:integration:bun && PW_SCOPE=all playwright test tests/integration/ --project=chromium",
    "test:integration:all": "bun run test:integration:bun && PW_SCOPE=all playwright test tests/integration/",
    "test:integration:headed": "bun run test:integration:bun && PW_SCOPE=integration playwright test --project=chromium --headed",
    "test:integration:migration": "PW_ENABLE_SIGNALING=0 playwright test tests/integration/migration-sync-convergence.spec.ts",
    "test:unit": "bun test tests/unit/",
    "test:e2e:live-smoke": "playwright test -c playwright.live-smoke.config.ts",
    "test:integration:bun": "bun test tests/integration/capability-peer-failure.spec.ts tests/integration/presence-slices.spec.ts tests/integration/public-channel-fanout.spec.ts tests/integration/public-workspace-mixed-client.spec.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@sveltejs/vite-plugin-svelte": "4",
    "decent-client-core": "workspace:^",
    "@decentchat/protocol": "workspace:^",
    "@decentchat/transport-webrtc": "workspace:^",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "peerjs": "^1.5.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "svelte": "^5.53.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-window": "^7.1.0",
    "ws": "^8.19.0"
  }
}
